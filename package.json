{
    "name": "formbar",
    "version": "3.0.0",
    "description": "Javascript rewrite of Formbar, an open source classroom management tool",
    "main": "app.js",
    "scripts": {
        "dev": "nodemon app",
        "start": "node app",
        "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js",
        "init-db": "node database/init.js",
        "migrate": "node database/migrate.js",
        "format": "prettier --write \"**/*.js\"",
        "format:check": "prettier --check \"**/*.js\""
    },
    "_moduleAliases": {
        "@modules": "modules",
        "@middleware": "middleware",
        "@services": "services",
        "@controllers": "api/v1/controllers",
        "@errors": "errors",
        "@sockets": "sockets",
        "@stores": "stores"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/csmith1188/Formbar.js.git"
    },
    "license": "YCSTEL-1.0",
    "bugs": {
        "url": "https://github.com/csmith1188/Formbar.js/issues"
    },
    "homepage": "https://github.com/csmith1188/Formbar.js#readme",
    "nodemonConfig": {
        "ignore": [
            "settings.json",
            "static/**"
        ]
    },
    "dependencies": {
        "@datalust/winston-seq": "^3.0.1",
        "bcrypt": "^6.0.0",
        "cors": "^2.8.6",
        "csv-parser": "^3.2.0",
        "dotenv": "^16.4.7",
        "express": "^4.18.2",
        "express-async-errors": "^3.1.1",
        "express-session": "^1.18.2",
        "handlebars": "^4.7.8",
        "jsonwebtoken": "^9.0.2",
        "module-alias": "^2.3.4",
        "nodemailer": "^8.0.5",
        "openid-client": "^6.8.2",
        "prettier": "^3.6.2",
        "socket.io": "^4.5.4",
        "sqlite3": "^6.0.1",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.1",
        "winston": "^3.11.0",
        "winston-daily-rotate-file": "^4.7.1"
    },
    "devDependencies": {
        "@types/jest": "^29.5.14",
        "jest": "^29.7.0",
        "nodemon": "^3.0.1",
        "supertest": "^7.1.0"
    }
}
